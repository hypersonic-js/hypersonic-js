{
  "name": "@hypersonic-js/test-app",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --experimental-strip-types server.ts",
    "build": "vite build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d --wait && npx prisma migrate reset --force",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@hypersonic-js/admin": "workspace:*",
    "@hypersonic-js/core": "workspace:*",
    "better-auth": "1.6.25",
    "@prisma/adapter-pg": "^7.9.0"
  },
  "devDependencies": {
    "@hypersonic-js/cli": "workspace:*",
    "@hypersonic-js/limits": "workspace:*",
    "@inertiajs/react": "3.6.1",
    "@prisma/client": "7.9.0",
    "@tailwindcss/vite": "4.3.3",
    "@types/express": "5.0.6",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/supertest": "7.2.1",
    "@vitest/coverage-v8": "4.1.10",
    "dotenv": "^17.4.2",
    "prisma": "7.9.0",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "redis": "6.1.0",
    "supertest": "7.2.2",
    "tailwindcss": "4.3.3",
    "typescript": "6.0.3",
    "vite": "8.1.5",
    "vitest": "4.1.10",
    "express": "5.2.1"
  }
}