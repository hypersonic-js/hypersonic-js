{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["vite/client"]
  },
  "include": [
    "*.ts",
    "server.ts",
    "vite.config.ts",
    "vitest.config.ts",
    "src/**/*",
    "tests/**/*",
    "resources/js/**/*"
  ]
}