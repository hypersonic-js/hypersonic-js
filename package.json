{
  "name": "hypersonic",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "type-check": "turbo type-check",
    "dev": "turbo dev",
    "clean": "turbo clean",
    "docs:dev": "turbo docs:dev",
    "docs:build": "turbo docs:build",
    "changeset": "changeset",
    "version": "changeset version",
    "licenses": "node --no-warnings=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/generate-licenses.ts",
    "release": "turbo build && node --no-warnings=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/generate-licenses.ts && changeset publish",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@types/node": "26.1.0",
    "eslint": "10.6.0",
    "globals": "17.7.0",
    "turbo": "2.10.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0"
  },
  "engines": {
    "node": ">=24.18.0"
  }
}