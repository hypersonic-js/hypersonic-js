{
  "name": "hypersonic",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "type-check": "turbo type-check",
    "dev": "turbo dev",
    "clean": "turbo clean",
    "changeset": "changeset",
    "version": "changeset version",
    "licenses": "node --no-warnings=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/generate-licenses.ts",
    "release": "turbo build && node --no-warnings=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/generate-licenses.ts && changeset publish",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@types/node": "25.9.1",
    "turbo": "2.9.15",
    "typescript": "6.0.3",
    "eslint": "10.4.0",
    "globals": "17.6.0",
    "typescript-eslint": "8.60.0"
  },
  "engines": {
    "node": "^24.0.0"
  }
}