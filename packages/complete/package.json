{
  "name": "@hypersonic-js/complete",
  "version": "0.2.7",
  "description": "The complete Hypersonic.js framework — all production packages in one install",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hypersonic-js/hypersonic-js"
  },
  "license": "MIT",
  "author": "Joaquim Dalton-Pereira",
  "homepage": "https://hypersonic-js.com",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@hypersonic-js/admin": "workspace:*",
    "@hypersonic-js/core": "workspace:*",
    "@hypersonic-js/limits": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "26.1.0",
    "@vitest/coverage-v8": "4.1.10",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}