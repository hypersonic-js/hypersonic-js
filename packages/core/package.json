{
  "name": "@hypersonic-js/core",
  "version": "0.2.7",
  "description": "The core of Hypersonic.js — a modern Django-inspired full-stack TypeScript framework",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hypersonic-js/hypersonic-js"
  },
  "author": "Joaquim Dalton-Pereira",
  "license": "MIT",
  "homepage": "https://hypersonic-js.com",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24.18.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@inertiajs/core": "3.6.1",
    "@inertiajs/react": "3.6.1",
    "@tailwindcss/vite": "4.3.2",
    "@vitejs/plugin-react": "6.0.3",
    "better-auth": "1.6.23",
    "express": "5.2.1",
    "helmet": "8.2.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "4.3.2",
    "vite": "8.1.3",
    "zod": "4.4.3"
  },
  "peerDependencies": {
    "@prisma/client": "^7.8.0",
    "prisma": "7.8.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/adapter-better-sqlite3": "7.8.0"
  },
  "peerDependenciesMeta": {
    "@prisma/adapter-pg": {
      "optional": true
    },
    "@prisma/adapter-better-sqlite3": {
      "optional": true
    }
  },
  "devDependencies": {
    "@prisma/client": "7.8.0",
    "@types/express": "5.0.6",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "4.1.10",
    "prisma": "7.8.0",
    "supertest": "7.2.2",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}