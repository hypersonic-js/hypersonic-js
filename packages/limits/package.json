{
  "name": "@hypersonic-js/limits",
  "version": "0.2.7",
  "description": "Rate limiting for Hypersonic.js — memory, database, and Redis backed",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hypersonic-js/hypersonic-js"
  },
  "license": "MIT",
  "author": "Joaquim Dalton-Pereira",
  "homepage": "https://hypersonic-js.com",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24.18.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "express-rate-limit": "8.5.2",
    "rate-limit-redis": "6.0.0"
  },
  "peerDependencies": {
    "@hypersonic-js/core": "workspace:*",
    "@prisma/client": "^7.8.0",
    "express": "^5.2.1",
    "redis": "^6.1.0"
  },
  "peerDependenciesMeta": {
    "redis": {
      "optional": true
    },
    "@prisma/client": {
      "optional": true
    }
  },
  "devDependencies": {
    "@hypersonic-js/core": "workspace:*",
    "@types/express": "5.0.6",
    "@types/node": "26.1.0",
    "@vitest/coverage-v8": "4.1.10",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}